# LLM
# Use http://host.docker.internal:PORT for native Ollama (recommended on macOS for Metal GPU)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Calendar (CalDAV)
CALDAV_URL=https://caldav.icloud.com
CALDAV_USERNAME=
CALDAV_PASSWORD=

# Email (IMAP)
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

# Notifications
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USER_IDS=  # Comma-separated Slack user IDs allowed to DM the bot (empty + API_KEY set = deny all)
# iMessage (macOS only, requires Messages.app)
IMESSAGE_RECIPIENT=

# Quiet hours (24h format, leave empty to disable)
QUIET_HOURS_START=
QUIET_HOURS_END=
QUIET_HOURS_BYPASS_URGENT=true

# Scanner intervals (minutes)
CALENDAR_SCAN_INTERVAL_MIN=5
EMAIL_SCAN_INTERVAL_MIN=10
NOTES_SCAN_INTERVAL_MIN=30
EVENT_ALERT_WINDOW_MIN=15
# Daily digest (hour in local time 0-23, uses quiet hours timezone)
DIGEST_ENABLED=true
DIGEST_HOUR=7

# Source health monitoring
HEALTH_CHECK_INTERVAL_MIN=5
HEALTH_STALE_MULTIPLIER=3.0
HEALTH_ALERT_COOLDOWN_MIN=60

# LLM Rate Limiting
LLM_DAILY_TOKEN_BUDGET=500000
LLM_RATE_LIMIT_RPM=30
LLM_BUDGET_WARNING_PCT=80

# Database
DATABASE_URL=sqlite:///data/assistant.db
CHROMA_PERSIST_DIR=./data/chroma

# Authentication (leave empty to disable auth in dev mode)
API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend (served by Caddy on port 3080 in production)
# Access the dashboard at http://localhost:3080
# API is also proxied through the frontend at http://localhost:3080/api/*
